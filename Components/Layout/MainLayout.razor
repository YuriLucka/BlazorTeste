@inherits LayoutComponentBase
@inject AppStateService AppState
@implements IDisposable

<MudThemeProvider Theme="_theme" IsDarkMode="AppState.DarkMode" />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Dense="false" Color="Color.Primary">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       OnClick="@(() => _drawerOpen = !_drawerOpen)" />
        <MudText Typo="Typo.h6" Class="ml-2 d-none d-sm-block" Style="letter-spacing:.5px;">
            SindERP
        </MudText>
        <MudSpacer />
        <MudTooltip Text="Trocar entidade">
            <MudChip T="string"
                     Icon="@Icons.Material.Filled.AccountTree"
                     Color="Color.Inherit"
                     Variant="Variant.Outlined"
                     Size="Size.Small"
                     Class="mr-1"
                     Style="color:white; border-color:rgba(255,255,255,0.6);"
                     Href="/entidades">
                @(AppState.EntidadeAtiva?.Sigla ?? "Selecionar entidade")
            </MudChip>
        </MudTooltip>
        <div class="appbar-breadcrumbs">
            <MudBreadcrumbs Items="@Breadcrumbs.ToList()" Separator=">" Class="ms-2 d-none d-sm-flex" />
        </div>
        <MudTooltip Text="@(AppState.DarkMode ? "Modo claro" : "Modo escuro")">
            <MudIconButton Icon="@(AppState.DarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                           Color="Color.Inherit"
                           OnClick="@(() => AppState.ToggleDarkMode())" />
        </MudTooltip>
        <MudMenu AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight" Dense="true">
            <ActivatorContent>
                <MudAvatar Color="Color.Secondary" Size="Size.Small" Class="ml-1" Style="cursor:pointer;">
                    @GetInitials(AppState.UsuarioLogado?.Nome)
                </MudAvatar>
            </ActivatorContent>
            <ChildContent>
                <div class="px-4 py-3">
                    <MudText Typo="Typo.subtitle2" Style="font-weight:600;">@(AppState.UsuarioLogado?.Nome ?? "Usuário")</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">@AppState.UsuarioLogado?.Email</MudText>
                </div>
                <MudDivider />
                <MudMenuItem Icon="@Icons.Material.Filled.Person">Perfil</MudMenuItem>
                <MudDivider />
                <MudMenuItem Icon="@Icons.Material.Filled.Logout" OnClick="@((MouseEventArgs _) => LogoutClick())">
                    <MudText Color="Color.Error">Sair</MudText>
                </MudMenuItem>
            </ChildContent>
        </MudMenu>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen"
               Elevation="2"
               Variant="@DrawerVariant.Responsive"
               ClipMode="DrawerClipMode.Never">
        <MudDrawerHeader Class="pa-4" Style="height:64px; display:flex; align-items:center;">
            <div>
                <MudText Typo="Typo.subtitle1" Color="Color.Primary" Style="font-weight:700; line-height:1.2;">SindERP</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">Sistema Sindical</MudText>
            </div>
        </MudDrawerHeader>
        <MudDivider Style="flex:none;" />
        <NavMenu />
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-4 mt-2">
            <ErrorBoundary @ref="_errorBoundary">
                <ChildContent>
                    @Body
                </ChildContent>
                <ErrorContent>
                    <MudAlert Severity="Severity.Error" Class="mt-4">
                        Ocorreu um erro inesperado.
                        <MudButton Variant="Variant.Text" OnClick="@(() => _errorBoundary?.Recover())">Tentar novamente</MudButton>
                    </MudAlert>
                </ErrorContent>
            </ErrorBoundary>
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;
    private ErrorBoundary? _errorBoundary;

    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private static readonly MudTheme _theme = new()
    {
        Palette = new PaletteLight
        {
            Primary = "#1565C0",
            Secondary = "#00897B",
            Background = "#F5F7FA",
            AppbarBackground = "#1565C0",
            DrawerBackground = "#FFFFFF"
        },
        PaletteDark = new PaletteDark
        {
            Primary = "#5C9CE6",
            Secondary = "#4DB6A6",
            Background = "#1A1A2E",
            Surface = "#16213E",
            AppbarBackground = "#0D1B2A",
            DrawerBackground = "#16213E"
        },
        LayoutProperties = new LayoutProperties
        {
            DefaultBorderRadius = "12px",
            DrawerWidthLeft = "240px"
        }
    };

    private IEnumerable<BreadcrumbItem> Breadcrumbs => GetBreadcrumbs();

    private IEnumerable<BreadcrumbItem> GetBreadcrumbs()
    {
        var uri = Navigation.ToBaseRelativePath(Navigation.Uri);
        var path = "/" + uri.TrimStart('/').Split('?')[0];

        var items = new List<BreadcrumbItem>
        {
            new BreadcrumbItem("Início", href: "/", icon: Icons.Material.Filled.Home)
        };

        var label = path switch
        {
            "/" => null,
            "/contribuintes" => "Contribuintes",
            "/cobrancas" => "Cobranças",
            "/juridico" => "Jurídico",
            "/financeiro" => "Financeiro",
            "/mailing" => "Mailing",
            "/entidades" => "Entidades",
            "/usuarios" => "Usuários",
            _ => null
        };

        if (label != null)
            items.Add(new BreadcrumbItem(label, href: null, disabled: true));

        return items;
    }

    protected override void OnInitialized()
    {
        AppState.OnChange += StateHasChanged;
        if (AppState.UsuarioLogado == null)
            Navigation.NavigateTo("/login", replace: true);
    }

    private void LogoutClick()
    {
        AppState.Logout();
        Navigation.NavigateTo("/login", replace: true);
    }

    private static string GetInitials(string? nome)
    {
        if (string.IsNullOrEmpty(nome)) return "?";
        var parts = nome.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length >= 2
            ? $"{parts[0][0]}{parts[1][0]}"
            : $"{parts[0][0]}";
    }

    public void Dispose()
    {
        AppState.OnChange -= StateHasChanged;
    }
}
