<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6" Color="Color.Error">Inativar Contribuinte</MudText>
    </TitleContent>
    <DialogContent>
        <MudAlert Severity="Severity.Warning" Class="mb-3">
            Esta ação irá inativar o contribuinte e suspender todas as cobranças futuras.
        </MudAlert>
        <MudText Typo="Typo.body1" Class="mb-3">
            Contribuinte: <strong>@NomeContribuinte</strong>
        </MudText>
        <MudTextField @bind-Value="_motivo" Label="Motivo da inativação *" Variant="Variant.Outlined"
                      Lines="3" Placeholder="Descreva o motivo..." />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => MudDialog.Cancel())">Cancelar</MudButton>
        <MudButton Color="Color.Error" Variant="Variant.Filled" OnClick="Confirmar"
                   StartIcon="@Icons.Material.Filled.PersonOff">
            Inativar
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private MudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public string NomeContribuinte { get; set; } = "";
    private string _motivo = "";
    private void Confirmar() => MudDialog.Close(DialogResult.Ok(_motivo));
}
