@inject IJSRuntime JS
@inject ISnackbar Snackbar
@inject CobrancaService CobrancaService

<div class="px-3 pt-3 pb-1">
    <MudTextField @bind-Value="_search"
                  Placeholder="Buscar no menu..."
                  Adornment="Adornment.Start"
                  AdornmentIcon="@Icons.Material.Filled.Search"
                  Variant="Variant.Outlined"
                  Margin="Margin.Dense"
                  Clearable="true"
                  Immediate="true"
                  Class="nav-search-field" />
</div>

<MudNavMenu Class="py-1">

    @* ── Dashboard ── *@
    @if (S("Dashboard"))
    {
        <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">
            Dashboard
        </MudNavLink>
    }

    @* ── Operacional ── *@
    @if (G("Contribuintes","Lista Geral","Cadastro","Importação em Lote","Histórico de Alterações",
           "Cobranças","Lista de Cobranças","Baixa de Cobrança","Negociação","Emissão de Boleto","Inadimplência"))
    {
        <MudDivider Class="my-2" />
        <MudText Typo="Typo.overline" Class="px-4 pb-1" Color="Color.Secondary">Operacional</MudText>

        @if (G("Contribuintes","Lista Geral","Cadastro","Importação em Lote","Histórico de Alterações"))
        {
            <MudNavGroup Title="Contribuintes" Icon="@Icons.Material.Filled.Business"
                         Expanded="@E("contrib","Contribuintes","Lista Geral","Cadastro","Importação em Lote","Histórico de Alterações")"
                         ExpandedChanged="@(v => SE("contrib", v))">
                @if (S("Lista Geral"))          { <MudNavLink Href="/contribuintes">Lista Geral</MudNavLink> }
                @if (S("Cadastro"))             { <MudNavLink Disabled="true">Cadastro</MudNavLink> }
                @if (S("Importação em Lote"))   { <MudNavLink Disabled="true">Importação em Lote</MudNavLink> }
                @if (S("Histórico de Alterações")) { <MudNavLink Disabled="true">Histórico de Alterações</MudNavLink> }
            </MudNavGroup>
        }

        @if (G("Cobranças","Lista de Cobranças","Baixa de Cobrança","Negociação","Emissão de Boleto","Inadimplência"))
        {
            <MudNavGroup Title="Cobranças" Icon="@Icons.Material.Filled.RequestQuote"
                         Expanded="@E("cobra","Cobranças","Lista de Cobranças","Baixa de Cobrança","Negociação","Emissão de Boleto","Inadimplência")"
                         ExpandedChanged="@(v => SE("cobra", v))">
                @if (S("Lista de Cobranças"))   { <MudNavLink Href="/cobrancas">Lista de Cobranças</MudNavLink> }
                @if (S("Baixa de Cobrança"))    { <MudNavLink Href="/baixa">Baixa de Cobrança</MudNavLink> }
                @if (S("Negociação"))           { <MudNavLink Href="/negociacao">Negociação</MudNavLink> }
                @if (S("Emissão de Boleto"))    { <MudNavLink Disabled="true">Emissão de Boleto</MudNavLink> }
                @if (S("Inadimplência"))        { <MudNavLink Disabled="true">Relatório de Inadimplência</MudNavLink> }
            </MudNavGroup>
        }
    }

    @* ── Módulos ── *@
    @if (G("Financeiro","Visão Geral Financeira","Lançamentos","Contas a Pagar","Contas a Receber","Fluxo de Caixa",
           "Jurídico","Processos","Audiências","Honorários","Certidões",
           "Mailing","Campanhas","Templates","Segmentação","Histórico de Disparos",
           "Eventos","Lista de Eventos","Inscrições","Certificados","Controle de Presenças",
           "Guia Sindical","Publicações","Categorias",
           "Negociações","Acordos Coletivos","Parcelas","Histórico de Negociações"))
    {
        <MudDivider Class="my-2" />
        <MudText Typo="Typo.overline" Class="px-4 pb-1" Color="Color.Secondary">Módulos</MudText>

        @if (G("Financeiro","Visão Geral Financeira","Lançamentos","Contas a Pagar","Contas a Receber","Fluxo de Caixa"))
        {
            <MudNavGroup Title="Financeiro" Icon="@Icons.Material.Filled.AccountBalance"
                         Expanded="@E("fin","Financeiro","Visão Geral Financeira","Lançamentos","Contas a Pagar","Contas a Receber","Fluxo de Caixa")"
                         ExpandedChanged="@(v => SE("fin", v))">
                @if (S("Visão Geral Financeira")) { <MudNavLink Href="/financeiro">Visão Geral</MudNavLink> }
                @if (S("Lançamentos"))           { <MudNavLink Disabled="true">Lançamentos</MudNavLink> }
                @if (S("Contas a Pagar"))        { <MudNavLink Disabled="true">Contas a Pagar</MudNavLink> }
                @if (S("Contas a Receber"))      { <MudNavLink Disabled="true">Contas a Receber</MudNavLink> }
                @if (S("Fluxo de Caixa"))        { <MudNavLink Disabled="true">Fluxo de Caixa</MudNavLink> }
            </MudNavGroup>
        }

        @if (G("Jurídico","Processos","Audiências","Honorários","Certidões"))
        {
            <MudNavGroup Title="Jurídico" Icon="@Icons.Material.Filled.Gavel"
                         Expanded="@E("jur","Jurídico","Processos","Audiências","Honorários","Certidões")"
                         ExpandedChanged="@(v => SE("jur", v))">
                @if (S("Processos"))   { <MudNavLink Href="/juridico">Processos</MudNavLink> }
                @if (S("Audiências")) { <MudNavLink Disabled="true">Audiências</MudNavLink> }
                @if (S("Honorários")) { <MudNavLink Disabled="true">Honorários</MudNavLink> }
                @if (S("Certidões"))  { <MudNavLink Disabled="true">Certidões</MudNavLink> }
            </MudNavGroup>
        }

        @if (G("Mailing","Campanhas","Templates","Segmentação","Histórico de Disparos"))
        {
            <MudNavGroup Title="Mailing" Icon="@Icons.Material.Filled.Email"
                         Expanded="@E("mail","Mailing","Campanhas","Templates","Segmentação","Histórico de Disparos")"
                         ExpandedChanged="@(v => SE("mail", v))">
                @if (S("Campanhas"))              { <MudNavLink Href="/mailing">Campanhas</MudNavLink> }
                @if (S("Templates"))              { <MudNavLink Disabled="true">Templates</MudNavLink> }
                @if (S("Segmentação"))            { <MudNavLink Disabled="true">Segmentação</MudNavLink> }
                @if (S("Histórico de Disparos"))  { <MudNavLink Disabled="true">Histórico de Disparos</MudNavLink> }
            </MudNavGroup>
        }

        @if (G("Eventos","Lista de Eventos","Inscrições","Certificados","Controle de Presenças"))
        {
            <MudNavGroup Title="Eventos" Icon="@Icons.Material.Filled.Event"
                         Expanded="@E("evt","Eventos","Lista de Eventos","Inscrições","Certificados","Controle de Presenças")"
                         ExpandedChanged="@(v => SE("evt", v))">
                @if (S("Lista de Eventos"))        { <MudNavLink Href="/eventos">Lista de Eventos</MudNavLink> }
                @if (S("Inscrições"))              { <MudNavLink Disabled="true">Inscrições</MudNavLink> }
                @if (S("Certificados"))            { <MudNavLink Disabled="true">Certificados</MudNavLink> }
                @if (S("Controle de Presenças"))   { <MudNavLink Disabled="true">Controle de Presenças</MudNavLink> }
            </MudNavGroup>
        }

        @if (G("Guia Sindical","Publicações","Categorias"))
        {
            <MudNavGroup Title="Guia Sindical" Icon="@Icons.Material.Filled.MenuBook"
                         Expanded="@E("guia","Guia Sindical","Publicações","Categorias")"
                         ExpandedChanged="@(v => SE("guia", v))">
                @if (S("Publicações"))  { <MudNavLink Href="/guia-sindical">Publicações</MudNavLink> }
                @if (S("Categorias"))   { <MudNavLink Disabled="true">Categorias</MudNavLink> }
            </MudNavGroup>
        }

        @if (G("Negociações","Acordos Coletivos","Parcelas","Histórico de Negociações"))
        {
            <MudNavGroup Title="Negociações" Icon="@Icons.Material.Filled.Handshake"
                         Expanded="@E("neg","Negociações","Acordos Coletivos","Parcelas","Histórico de Negociações")"
                         ExpandedChanged="@(v => SE("neg", v))">
                @if (S("Acordos Coletivos"))          { <MudNavLink Href="/negociacao">Acordos Coletivos</MudNavLink> }
                @if (S("Parcelas"))                   { <MudNavLink Disabled="true">Parcelas</MudNavLink> }
                @if (S("Histórico de Negociações"))   { <MudNavLink Disabled="true">Histórico</MudNavLink> }
            </MudNavGroup>
        }
    }

    @* ── Relatórios ── *@
    @if (G("Relatórios","Visão Geral","Por Contribuinte","Por Período","Relatório Financeiro","Inadimplência","Exportações"))
    {
        <MudDivider Class="my-2" />
        <MudText Typo="Typo.overline" Class="px-4 pb-1" Color="Color.Secondary">Relatórios</MudText>

        <MudNavGroup Title="Relatórios" Icon="@Icons.Material.Filled.Assessment"
                     Expanded="@E("rel","Relatórios","Visão Geral","Por Contribuinte","Por Período","Relatório Financeiro","Inadimplência","Exportações")"
                     ExpandedChanged="@(v => SE("rel", v))">
            @if (S("Visão Geral"))          { <MudNavLink Href="/relatorios">Visão Geral</MudNavLink> }
            @if (S("Por Contribuinte"))     { <MudNavLink Disabled="true">Por Contribuinte</MudNavLink> }
            @if (S("Por Período"))          { <MudNavLink Disabled="true">Por Período</MudNavLink> }
            @if (S("Relatório Financeiro")) { <MudNavLink Disabled="true">Financeiro</MudNavLink> }
            @if (S("Inadimplência"))        { <MudNavLink Disabled="true">Inadimplência</MudNavLink> }
            @if (S("Exportações"))          { <MudNavLink Disabled="true">Exportações</MudNavLink> }
        </MudNavGroup>
    }

    @* ── Administração ── *@
    @if (G("Entidades","Cadastro de Entidades","Convênios","Filiais",
           "Configurações","Geral","Banco","E-mail SMTP","Integrações",
           "Usuários","Lista de Usuários","Perfis de Acesso","Permissões","Auditoria de Acessos"))
    {
        <MudDivider Class="my-2" />
        <MudText Typo="Typo.overline" Class="px-4 pb-1" Color="Color.Secondary">Administração</MudText>

        @if (G("Entidades","Cadastro de Entidades","Convênios","Filiais"))
        {
            <MudNavGroup Title="Entidades" Icon="@Icons.Material.Filled.AccountTree"
                         Expanded="@E("ent","Entidades","Cadastro de Entidades","Convênios","Filiais")"
                         ExpandedChanged="@(v => SE("ent", v))">
                @if (S("Cadastro de Entidades")) { <MudNavLink Href="/entidades">Cadastro de Entidades</MudNavLink> }
                @if (S("Convênios"))             { <MudNavLink Disabled="true">Convênios</MudNavLink> }
                @if (S("Filiais"))               { <MudNavLink Disabled="true">Filiais</MudNavLink> }
            </MudNavGroup>
        }

        @if (G("Configurações","Geral","Banco","E-mail SMTP","Integrações"))
        {
            <MudNavGroup Title="Configurações" Icon="@Icons.Material.Filled.Settings"
                         Expanded="@E("cfg","Configurações","Geral","Banco","E-mail SMTP","Integrações")"
                         ExpandedChanged="@(v => SE("cfg", v))">
                @if (S("Geral"))        { <MudNavLink Href="/configuracoes">Geral</MudNavLink> }
                @if (S("Banco"))        { <MudNavLink Disabled="true">Banco</MudNavLink> }
                @if (S("E-mail SMTP"))  { <MudNavLink Disabled="true">E-mail SMTP</MudNavLink> }
                @if (S("Integrações"))  { <MudNavLink Disabled="true">Integrações</MudNavLink> }
            </MudNavGroup>
        }

        @if (G("Usuários","Lista de Usuários","Perfis de Acesso","Permissões","Auditoria de Acessos"))
        {
            <MudNavGroup Title="Usuários" Icon="@Icons.Material.Filled.People"
                         Expanded="@E("usr","Usuários","Lista de Usuários","Perfis de Acesso","Permissões","Auditoria de Acessos")"
                         ExpandedChanged="@(v => SE("usr", v))">
                @if (S("Lista de Usuários"))      { <MudNavLink Href="/usuarios">Lista de Usuários</MudNavLink> }
                @if (S("Perfis de Acesso"))       { <MudNavLink Disabled="true">Perfis de Acesso</MudNavLink> }
                @if (S("Permissões"))             { <MudNavLink Disabled="true">Permissões</MudNavLink> }
                @if (S("Auditoria de Acessos"))   { <MudNavLink Disabled="true">Auditoria de Acessos</MudNavLink> }
            </MudNavGroup>
        }
    }

    @* ── Interações ── *@
    @if (G("Notificações","Simples","Persistente","Silenciosa","Urgente","Ao clicar abre app","Com Imagem","Com Ação","Dinâmica (DB)"))
    {
        <MudDivider Class="my-2" />
        <MudText Typo="Typo.overline" Class="px-4 pb-1" Color="Color.Secondary">Interações</MudText>
        <MudNavGroup Title="Notificações" Icon="@Icons.Material.Filled.NotificationsActive"
                     Expanded="@E("notif","Notificações","Simples","Persistente","Silenciosa","Urgente","Ao clicar abre app","Com Imagem","Com Ação","Dinâmica (DB)")"
                     ExpandedChanged="@(v => SE("notif", v))">
            @if (S("Simples"))              { <MudNavLink OnClick="@(() => Notificar("simples"))">Simples</MudNavLink> }
            @if (S("Persistente"))          { <MudNavLink OnClick="@(() => Notificar("persistente"))">Persistente</MudNavLink> }
            @if (S("Silenciosa"))           { <MudNavLink OnClick="@(() => Notificar("silenciosa"))">Silenciosa</MudNavLink> }
            @if (S("Urgente"))              { <MudNavLink OnClick="@(() => Notificar("urgente"))">Urgente</MudNavLink> }
            @if (S("Ao clicar abre app"))   { <MudNavLink OnClick="@(() => Notificar("clique"))">Ao clicar abre app</MudNavLink> }
            @if (S("Com Imagem"))           { <MudNavLink OnClick="@(() => Notificar("imagem"))">Com Imagem</MudNavLink> }
            @if (S("Com Ação"))             { <MudNavLink OnClick="@(() => NotificarComAcao())">Com Ação</MudNavLink> }
            @if (S("Dinâmica (DB)"))        { <MudNavLink OnClick="@(() => NotificarDinamica())">Dinâmica (DB)</MudNavLink> }
        </MudNavGroup>
    }

</MudNavMenu>

<style>
    .nav-search-field .mud-input-outlined .mud-input {
        font-size: 0.8125rem;
    }
    .mud-nav-link.disabled {
        opacity: 0.4;
        cursor: default;
        pointer-events: none;
    }
</style>

@code {
    private string _search = "";
    private bool AnySearch => !string.IsNullOrWhiteSpace(_search);
    private readonly Dictionary<string, bool> _exp = new();

    private bool S(string label)
        => !AnySearch || label.Contains(_search.Trim(), StringComparison.OrdinalIgnoreCase);

    private bool G(params string[] labels)
        => !AnySearch || labels.Any(l => l.Contains(_search.Trim(), StringComparison.OrdinalIgnoreCase));

    private bool E(string key, params string[] labels)
    {
        if (AnySearch) return G(labels);
        _exp.TryGetValue(key, out var v);
        return v;
    }

    private void SE(string key, bool value)
    {
        if (!AnySearch) _exp[key] = value;
    }

    private async Task Notificar(string tipo)
    {
        var opts = tipo switch
        {
            "simples" => new
            {
                title = "SindERP",
                body = "Notificação simples — aparece por 6 segundos e fecha sozinha.",
                icon = "/favicon.png",
                image = (string?)null,
                silent = false,
                requireInteraction = false,
                renotify = false,
                tag = "sinderp-simples",
                url = (string?)null,
                duration = 6000
            },
            "persistente" => new
            {
                title = "SindERP — Atenção",
                body = "Notificação persistente — fica na tela até você fechar manualmente.",
                icon = "/favicon.png",
                image = (string?)null,
                silent = false,
                requireInteraction = true,
                renotify = true,
                tag = "sinderp-persistente",
                url = (string?)null,
                duration = 0
            },
            "silenciosa" => new
            {
                title = "SindERP",
                body = "Notificação silenciosa — sem som, sem vibração.",
                icon = "/favicon.png",
                image = (string?)null,
                silent = true,
                requireInteraction = false,
                renotify = false,
                tag = "sinderp-silenciosa",
                url = (string?)null,
                duration = 6000
            },
            "urgente" => new
            {
                title = "⚠️ SindERP — URGENTE",
                body = "51 cobranças vencidas aguardam ação imediata!",
                icon = "/favicon.png",
                image = (string?)null,
                silent = false,
                requireInteraction = true,
                renotify = true,
                tag = "sinderp-urgente",
                url = (string?)null,
                duration = 0
            },
            "imagem" => new
            {
                title = "SindERP — Com Imagem",
                body = "Notificação com imagem no corpo (requer Chrome desktop).",
                icon = "/favicon.png",
                image = "https://picsum.photos/seed/sinderp/400/200",
                silent = false,
                requireInteraction = false,
                renotify = false,
                tag = "sinderp-imagem",
                url = (string?)null,
                duration = 10000
            },
            _ => new
            {
                title = "SindERP",
                body = "Clique aqui para abrir o Dashboard.",
                icon = "/favicon.png",
                image = (string?)null,
                silent = false,
                requireInteraction = false,
                renotify = false,
                tag = "sinderp-clique",
                url = (string?)"/",
                duration = 8000
            }
        };

        var result = await JS.InvokeAsync<string>("sinderpNotifications.send", opts);

        var msg = result switch
        {
            "granted"     => null,
            "denied"      => "Notificações bloqueadas pelo navegador.",
            "unsupported" => "Navegador não suporta notificações.",
            _             => "Permissão não concedida."
        };

        if (msg != null)
            Snackbar.Add(msg, Severity.Warning);
    }

    private async Task NotificarDinamica()
    {
        List<Cobranca> lista;
        try { lista = await CobrancaService.GetAllAsync(); }
        catch { Snackbar.Add("Erro ao buscar cobranças.", Severity.Error); return; }

        if (lista.Count == 0) { Snackbar.Add("Nenhuma cobrança encontrada.", Severity.Warning); return; }

        var c = lista[Random.Shared.Next(lista.Count)];
        var statusKey  = c.Status.ToString().ToLower();
        var valorFmt   = c.Valor.ToString("C", new System.Globalization.CultureInfo("pt-BR"));
        var vencFmt    = c.Vencimento.ToString("dd/MM/yyyy");
        var statusDesc = c.Status switch
        {
            StatusCobranca.Pago      => "✓ Pago",
            StatusCobranca.Vencido   => "⚠️ Vencido",
            StatusCobranca.Pendente  => "Pendente",
            StatusCobranca.Cancelado => "Cancelado",
            _                        => c.Status.ToString()
        };

        var avatarUrl = "/img/avatar-teste.jpg";

        var imageDataUrl = await JS.InvokeAsync<string>(
            "sinderpNotifications.gerarImagemCobranca",
            statusKey, c.RazaoSocialContribuinte, valorFmt, vencFmt, avatarUrl);

        var opts = new
        {
            title    = $"SindERP — {statusDesc}",
            body     = $"{c.RazaoSocialContribuinte}\n{valorFmt}  ·  Venc. {vencFmt}",
            icon     = "/favicon.png",
            image    = imageDataUrl,
            silent   = false,
            requireInteraction = false,
            renotify = true,
            tag      = "sinderp-dinamica",
            url      = (string?)"/cobrancas",
            duration = 12000
        };

        var result = await JS.InvokeAsync<string>("sinderpNotifications.send", opts);
        if (result is "denied")      Snackbar.Add("Notificações bloqueadas.", Severity.Warning);
        else if (result is "unsupported") Snackbar.Add("Navegador não suporta notificações.", Severity.Warning);
    }

    private async Task NotificarComAcao()
    {
        var opts = new
        {
            title = "SindERP — Cobrança Vencida",
            body = "R$ 1.747,36 — Choperia Malte Dourado LTDA",
            icon = "/favicon.png",
            image = (string?)null,
            silent = false,
            requireInteraction = true,
            renotify = true,
            tag = "sinderp-acao",
            url = "/cobrancas",
            actionButtons = new[]
            {
                new { action = "baixar", title = "Registrar Baixa" },
                new { action = "ver",    title = "Ver Detalhes" }
            },
            actions = new Dictionary<string, string>
            {
                ["baixar"] = "/baixa",
                ["ver"]    = "/cobrancas"
            }
        };

        var result = await JS.InvokeAsync<string>("sinderpNotifications.sendWithActions", opts);

        var msg = result switch
        {
            "granted"     => null,
            "no-sw"       => "Service Worker não disponível (requer HTTPS).",
            "denied"      => "Notificações bloqueadas pelo navegador.",
            "unsupported" => "Navegador não suporta notificações.",
            _             => "Permissão não concedida."
        };

        if (msg != null)
            Snackbar.Add(msg, Severity.Warning);
    }
}
