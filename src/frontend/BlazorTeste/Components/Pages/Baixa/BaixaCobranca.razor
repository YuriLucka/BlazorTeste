@page "/baixa"
@inject BaixaCobrancaService BaixaCobrancaService
@inject CobrancaService CobrancaService
@inject ISnackbar Snackbar

<PageTitle>Baixa de Cobranças — SindERP</PageTitle>

<div class="d-flex align-center justify-space-between mb-4">
    <div>
        <MudText Typo="Typo.h5" Style="font-weight:600;">Baixa de Cobranças</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">Registrar pagamentos manualmente ou via arquivo bancário</MudText>
    </div>
</div>

<!-- KPI -->
<MudGrid Spacing="3" Class="mb-4">
    <MudItem xs="12" sm="4">
        <MudCard Elevation="2" Class="rounded-xl">
            <MudCardContent Class="pa-4">
                <div class="d-flex align-center justify-space-between">
                    <div>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Baixas Hoje</MudText>
                        <MudText Typo="Typo.h6" Style="font-weight:700;">@_historico.Count(b => b.DataProcessamento.Date == DateTime.Today)</MudText>
                    </div>
                    <MudIcon Icon="@Icons.Material.Filled.Today" Color="Color.Primary" Style="font-size:2.2rem;" />
                </div>
            </MudCardContent>
        </MudCard>
    </MudItem>
    <MudItem xs="12" sm="4">
        <MudCard Elevation="2" Class="rounded-xl">
            <MudCardContent Class="pa-4">
                <div class="d-flex align-center justify-space-between">
                    <div>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Total Baixado Hoje</MudText>
                        <MudText Typo="Typo.h6" Style="font-weight:700;">
                            @_historico.Where(b => b.DataProcessamento.Date == DateTime.Today).Sum(b => b.ValorPago).ToString("C2")
                        </MudText>
                    </div>
                    <MudIcon Icon="@Icons.Material.Filled.Payments" Color="Color.Success" Style="font-size:2.2rem;" />
                </div>
            </MudCardContent>
        </MudCard>
    </MudItem>
    <MudItem xs="12" sm="4">
        <MudCard Elevation="2" Class="rounded-xl">
            <MudCardContent Class="pa-4">
                <div class="d-flex align-center justify-space-between">
                    <div>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Via Arquivo (mês)</MudText>
                        <MudText Typo="Typo.h6" Style="font-weight:700;">
                            @_historico.Count(b => b.TipoBaixa == TipoBaixa.ArquivoRetorno)
                        </MudText>
                    </div>
                    <MudIcon Icon="@Icons.Material.Filled.UploadFile" Color="Color.Info" Style="font-size:2.2rem;" />
                </div>
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>

<MudCard Elevation="2" Class="rounded-xl">
    <MudCardContent Class="pt-0">
        <MudTabs Elevation="0" PanelClass="pt-3">

            <!-- Baixa Manual -->
            <MudTabPanel Text="Baixa Manual" Icon="@Icons.Material.Filled.Edit">
                <MudAlert Severity="Severity.Info" Class="mb-3" Dense="true">
                    Selecione as cobranças e registre o pagamento manualmente.
                </MudAlert>
                <MudTable T="Cobranca" Items="_pendentes" Dense="true" Hover="true" Elevation="0"
                          MultiSelection="true" @bind-SelectedItems="_selecionadas">
                    <HeaderContent>
                        <MudTh>Contribuinte</MudTh>
                        <MudTh>Tipo</MudTh>
                        <MudTh>Valor</MudTh>
                        <MudTh>Vencimento</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd><strong>@context.RazaoSocialContribuinte</strong></MudTd>
                        <MudTd>@context.Tipo</MudTd>
                        <MudTd>@context.Valor.ToString("C2")</MudTd>
                        <MudTd Style="@(context.Vencimento < DateTime.Today ? "color:var(--mud-palette-error);" : "")">
                            @context.Vencimento.ToString("dd/MM/yyyy")
                        </MudTd>
                    </RowTemplate>
                </MudTable>
                <div class="mt-3">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               Disabled="@(!_selecionadas.Any())"
                               StartIcon="@Icons.Material.Filled.PriceCheck"
                               OnClick="@(() => _dialogOpen = true)">
                        Registrar Baixa (@_selecionadas.Count selecionada(s))
                    </MudButton>
                </div>
            </MudTabPanel>

            <!-- Arquivo Retorno -->
            <MudTabPanel Text="Arquivo de Retorno" Icon="@Icons.Material.Filled.UploadFile">
                <MudAlert Severity="Severity.Info" Class="mb-4" Dense="true">
                    Envie o arquivo de retorno bancário (.RET) para processar os pagamentos automaticamente.
                </MudAlert>

                <MudPaper Outlined="true" Class="pa-8 text-center rounded-xl mb-4" Style="border-style:dashed; cursor:pointer; border-color:var(--mud-palette-primary);"
                          @onclick="@(() => Snackbar.Add("Selecione o arquivo .RET no gerenciador de arquivos", Severity.Info))">
                    <MudIcon Icon="@Icons.Material.Filled.CloudUpload" Color="Color.Primary" Style="font-size:3rem;" />
                    <MudText Typo="Typo.subtitle1" Class="mt-2">Arraste o arquivo .RET aqui</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">ou clique para selecionar</MudText>
                </MudPaper>

                <div class="d-flex gap-2">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.PlayArrow"
                               OnClick="SimularProcessamento">
                        Processar Arquivo
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Download"
                               OnClick="@(() => Snackbar.Add("Baixando layout do arquivo de retorno...", Severity.Info))">
                        Baixar Layout
                    </MudButton>
                </div>

                @if (_processando)
                {
                    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mt-3" />
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-1">Processando arquivo...</MudText>
                }
            </MudTabPanel>

            <!-- Histórico -->
            <MudTabPanel Text="Histórico" BadgeData="@_historico.Count" BadgeColor="Color.Default">
                <MudTable T="RegistroBaixa" Items="_historico" Dense="true" Hover="true" Elevation="0">
                    <HeaderContent>
                        <MudTh>Data Pagamento</MudTh>
                        <MudTh>Contribuinte</MudTh>
                        <MudTh>Tipo</MudTh>
                        <MudTh>Valor Pago</MudTh>
                        <MudTh>Via</MudTh>
                        <MudTh>Operador</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.DataPagamento.ToString("dd/MM/yyyy")</MudTd>
                        <MudTd><strong>@context.RazaoSocialContribuinte</strong></MudTd>
                        <MudTd>@context.TipoCobranca</MudTd>
                        <MudTd><strong>@context.ValorPago.ToString("C2")</strong></MudTd>
                        <MudTd>
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Filled"
                                     Color="@(context.TipoBaixa == TipoBaixa.Manual ? Color.Primary : context.TipoBaixa == TipoBaixa.ArquivoRetorno ? Color.Info : Color.Success)">
                                @context.TipoBaixa
                            </MudChip>
                        </MudTd>
                        <MudTd>@context.OperadorResponsavel</MudTd>
                    </RowTemplate>
                </MudTable>
            </MudTabPanel>

        </MudTabs>
    </MudCardContent>
</MudCard>

<!-- Dialog Baixa Manual -->
<MudDialog @bind-IsVisible="_dialogOpen">
    <TitleContent>
        <MudText Typo="Typo.h6">Registrar Baixa Manual</MudText>
    </TitleContent>
    <DialogContent>
        <MudText Typo="Typo.body2" Class="mb-3">
            Registrar pagamento de <strong>@_selecionadas.Count</strong> cobrança(s) totalizando
            <strong>@_selecionadas.Sum(s => s.Valor).ToString("C2")</strong>.
        </MudText>
        <MudDatePicker @bind-Date="_dataPagamento" Label="Data do Pagamento" Variant="Variant.Outlined" Class="mb-3" />
        <MudTextField @bind-Value="_obsManual" Label="Observações" Variant="Variant.Outlined" Lines="2" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _dialogOpen = false)">Cancelar</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ConfirmarBaixa">
            Confirmar
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<RegistroBaixa> _historico = new();
    private List<Cobranca> _pendentes = new();
    private HashSet<Cobranca> _selecionadas = new();
    private bool _dialogOpen;
    private bool _processando;
    private DateTime? _dataPagamento = DateTime.Today;
    private string _obsManual = "";

    protected override async Task OnInitializedAsync()
    {
        _historico = await BaixaCobrancaService.GetHistoricoAsync();
        var todas = await CobrancaService.GetAllAsync();
        _pendentes = todas.Where(c => c.Status is StatusCobranca.Pendente or StatusCobranca.Vencido).ToList();
    }

    private void ConfirmarBaixa()
    {
        var count = _selecionadas.Count;
        _selecionadas.Clear();
        _dialogOpen = false;
        Snackbar.Add($"{count} cobrança(s) baixada(s) com sucesso!", Severity.Success);
    }

    private async Task SimularProcessamento()
    {
        _processando = true;
        StateHasChanged();
        await Task.Delay(3000);
        _processando = false;
        Snackbar.Add("Arquivo processado: 12 cobranças baixadas, 0 erros.", Severity.Success);
    }

}
