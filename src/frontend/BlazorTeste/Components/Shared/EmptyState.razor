@* Shared empty state component — used when a list/query returns no results *@

<div class="d-flex flex-column align-center justify-center pa-8" style="gap:12px; opacity:.65;">
    <MudIcon Icon="@Icon" Style="font-size:3.5rem;" Color="Color.Default" />
    <MudText Typo="Typo.h6" Align="Align.Center" Style="font-weight:600;">@Title</MudText>
    @if (!string.IsNullOrEmpty(Message))
    {
        <MudText Typo="Typo.body2" Align="Align.Center" Color="Color.Secondary">@Message</MudText>
    }
    @if (ActionContent != null)
    {
        <div class="mt-2">@ActionContent</div>
    }
</div>

@code {
    [Parameter] public string Icon { get; set; } = Icons.Material.Outlined.Inbox;
    [Parameter] public string Title { get; set; } = "Nenhum item encontrado";
    [Parameter] public string Message { get; set; } = "";
    [Parameter] public RenderFragment? ActionContent { get; set; }
}
